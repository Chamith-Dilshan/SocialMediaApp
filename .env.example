APP_NAME=name
APP_VERSION=1.0.0
DEBUG=True

API_V1_PREFIX=/api/v1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fastapi_crud
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

#DATABASE_URL=postgresql://<username>:<password>@<ip-address/hostname>:<port>/<database_name>
DATABASE_URL=postgresql+asyncpg://<username>:<password>@<ip-address/hostname>:<port>/<database_name>

#   Character	Percent Encoding	Used For
#   #	%23	Anchor/fragment identifier (creates URL fragments like #section)
#   $	%24	Dollar sign (often used in query parameters or database URIs)
#   &	%26	Separates query parameters
#   %   %25 percent sign
#   ?	%3F	Starts query string
#   =	%3D	Separates parameter names from values
#   /	%2F	Path separator (encoded when it shouldn't be treated as a path)
#   space	%20	Space character
#   +	%2B	Plus sign